{
  "name": "gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted infrastructure control plane",
  "scripts": {
    "dev": "nx run backend:dev",
    "dev:frontend": "nx run frontend:dev",
    "dev:status-page": "nx run status-page:dev",
    "dev:all": "nx run-many -t dev -p backend frontend status-page --parallel",
    "build": "nx run-many -t build -p backend frontend status-page logging-sdk",
    "build:all": "pnpm run build && pnpm run build:daemon",
    "build:backend": "nx run backend:build",
    "build:frontend": "nx run frontend:build",
    "build:logging-sdk": "nx run logging-sdk:build",
    "build:daemon": "scripts/sync-update-trust-anchor.sh && make -C packages/daemons/nginx build && make -C packages/daemons/docker build && mkdir -p packages/daemons/monitoring/bin && cd packages/daemons/monitoring && CGO_ENABLED=0 go build -o bin/monitoring-daemon ./cmd/monitoring-daemon",
    "start": "nx run backend:start",
    "test": "pnpm run test:backend && pnpm --filter frontend test && pnpm run test:logging-sdk && pnpm run test:daemon",
    "test:backend": "nx run backend:test",
    "test:logging-sdk": "nx run logging-sdk:test",
    "test:daemon": "scripts/sync-update-trust-anchor.sh && cd packages/daemons && go test ./docker/... ./monitoring/... ./nginx/... ./shared/...",
    "lint": "pnpm --filter frontend lint && pnpm --filter backend lint && pnpm --filter @wiolett/gateway-logger lint && pnpm run lint:daemon",
    "lint:daemon": "scripts/sync-update-trust-anchor.sh && cd packages/daemons && go vet ./docker/... ./monitoring/... ./nginx/... ./shared/...",
    "typecheck": "nx run-many -t typecheck -p backend logging-sdk",
    "typecheck:logging-sdk": "nx run logging-sdk:typecheck",
    "proto": "nx run nginx-daemon:proto",
    "db:generate": "nx run backend:db:generate",
    "db:migrate": "nx run backend:db:migrate",
    "db:studio": "nx run backend:db:studio",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "graph": "nx graph"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13",
      "axios": "1.16.0",
      "follow-redirects": "1.16.0",
      "fast-uri": "3.1.2",
      "hono": "4.12.25",
      "postcss": "8.5.10",
      "protobufjs": "7.6.3",
      "esbuild": "0.25.12",
      "vite": "7.3.5",
      "ip-address": "10.1.1",
      "@protobufjs/utf8": "1.1.1",
      "ws": "8.21.0",
      "qs": "6.15.2",
      "react-router": "7.18.1",
      "brace-expansion": "5.0.6",
      "@grpc/grpc-js": "1.14.4",
      "tmp": "0.2.7",
      "form-data": "4.0.6",
      "@babel/core": "7.29.6",
      "js-yaml@3.15.0": "4.2.0",
      "js-yaml@4.1.1": "4.2.0"
    }
  },
  "devDependencies": {
    "nx": "22.6.3"
  }
}
