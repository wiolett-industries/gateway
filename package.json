{
  "name": "gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Self-hosted certificate manager and reverse proxy gateway",
  "scripts": {
    "dev": "nx run backend:dev",
    "dev:frontend": "nx run frontend:dev",
    "dev:all": "nx run-many -t dev -p backend frontend --parallel",
    "build": "nx run-many -t build -p backend frontend",
    "build:all": "nx run-many -t build",
    "build:backend": "nx run backend:build",
    "build:frontend": "nx run frontend:build",
    "build:daemon": "nx run nginx-daemon:build",
    "start": "nx run backend:start",
    "test": "nx run-many -t test",
    "test:backend": "nx run backend:test",
    "test:daemon": "nx run nginx-daemon:test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run backend:typecheck",
    "proto": "nx run nginx-daemon:proto",
    "db:generate": "nx run backend:db:generate",
    "db:migrate": "nx run backend:db:migrate",
    "db:studio": "nx run backend:db:studio",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "graph": "nx graph"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "nx": "22.6.3"
  }
}
