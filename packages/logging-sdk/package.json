{
  "name": "@wiolett/gateway-logger",
  "version": "1.1.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://gitlab.wiolett.net/wiolett/gateway.git",
    "directory": "packages/logging-sdk"
  },
  "bugs": {
    "url": "https://gitlab.wiolett.net/wiolett/gateway/-/issues"
  },
  "homepage": "https://gitlab.wiolett.net/wiolett/gateway/-/tree/main/packages/logging-sdk#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": ["dist", "!dist/**/*.test.*"],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  }
}
