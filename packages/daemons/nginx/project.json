{
  "name": "nginx-daemon",
  "root": "packages/daemons/nginx",
  "sourceRoot": "packages/daemons/nginx",
  "targets": {
    "proto": {
      "command": "make -C packages/daemons/nginx proto",
      "inputs": ["{workspaceRoot}/proto/**/*.proto"],
      "outputs": ["{projectRoot}/internal/gatewayv1/*.pb.go"],
      "cache": true
    },
    "build": {
      "command": "make -C packages/daemons/nginx build",
      "dependsOn": ["proto"],
      "inputs": [
        "{projectRoot}/**/*.go",
        "{projectRoot}/go.mod",
        "{projectRoot}/go.sum",
        "{workspaceRoot}/packages/daemons/shared/**/*",
        "{workspaceRoot}/config/update-trust/**/*",
        "{workspaceRoot}/scripts/sync-update-trust-anchor.sh"
      ],
      "outputs": ["{projectRoot}/bin/nginx-daemon"],
      "cache": true
    },
    "test": {
      "command": "scripts/sync-update-trust-anchor.sh && cd packages/daemons/nginx && CGO_ENABLED=0 go test ./...",
      "dependsOn": ["proto"],
      "inputs": [
        "{projectRoot}/**/*.go",
        "{projectRoot}/**/*_test.go",
        "{workspaceRoot}/packages/daemons/shared/**/*",
        "{workspaceRoot}/config/update-trust/**/*",
        "{workspaceRoot}/scripts/sync-update-trust-anchor.sh"
      ],
      "cache": true
    },
    "lint": {
      "command": "scripts/sync-update-trust-anchor.sh && cd packages/daemons/nginx && CGO_ENABLED=0 go vet ./...",
      "dependsOn": ["proto"],
      "inputs": [
        "{projectRoot}/**/*.go",
        "{workspaceRoot}/packages/daemons/shared/**/*",
        "{workspaceRoot}/config/update-trust/**/*",
        "{workspaceRoot}/scripts/sync-update-trust-anchor.sh"
      ],
      "cache": true
    },
    "clean": {
      "command": "make -C packages/daemons/nginx clean",
      "cache": false
    }
  }
}
