{
  "name": "backend",
  "root": "packages/backend",
  "sourceRoot": "packages/backend/src",
  "targets": {
    "build": {
      "command": "pnpm --filter backend build",
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/package.json",
        "{workspaceRoot}/config/update-trust/**/*",
        "{workspaceRoot}/scripts/sync-update-trust-anchor.sh"
      ],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "dev": {
      "command": "pnpm --filter backend dev",
      "cache": false
    },
    "start": {
      "command": "pnpm --filter backend start",
      "cache": false
    },
    "test": {
      "command": "pnpm --filter backend test",
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/vitest.config.*",
        "{workspaceRoot}/config/update-trust/**/*",
        "{workspaceRoot}/scripts/sync-update-trust-anchor.sh"
      ],
      "cache": true
    },
    "lint": {
      "command": "pnpm --filter backend lint",
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/biome.json",
        "{projectRoot}/package.json",
        "{projectRoot}/vitest.config.*",
        "{workspaceRoot}/config/update-trust/**/*",
        "{workspaceRoot}/scripts/sync-update-trust-anchor.sh"
      ],
      "cache": true
    },
    "typecheck": {
      "command": "pnpm --filter backend typecheck",
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{workspaceRoot}/config/update-trust/**/*",
        "{workspaceRoot}/scripts/sync-update-trust-anchor.sh"
      ],
      "cache": true
    },
    "db:generate": {
      "command": "pnpm --filter backend db:generate",
      "cache": false
    },
    "db:migrate": {
      "command": "pnpm --filter backend db:migrate",
      "cache": false
    },
    "db:studio": {
      "command": "pnpm --filter backend db:studio",
      "cache": false
    }
  }
}
