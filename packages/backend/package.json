{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --import tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --import tsx src/db/migrate.ts",
    "db:migrate:drizzle": "node --import tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node --import tsx node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node --import tsx node_modules/drizzle-kit/bin.cjs studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-openapi": "^0.18.4",
    "@peculiar/asn1-ocsp": "^2.3.13",
    "@peculiar/asn1-schema": "^2.3.13",
    "@peculiar/asn1-x509": "^2.3.13",
    "@peculiar/x509": "^1.12.3",
    "@scalar/hono-api-reference": "^0.5.169",
    "acme-client": "^5.4.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.38.3",
    "handlebars": "^4.7.9",
    "hono": "^4.6.16",
    "ioredis": "^5.4.2",
    "nanoid": "^5.0.9",
    "node-cron": "^4.2.1",
    "node-forge": "^1.3.1",
    "openai": "^6.33.0",
    "openid-client": "^6.3.1",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/node-forge": "^1.3.11",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.17.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
