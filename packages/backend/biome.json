{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "files": {
    "includes": [
      "src/**/*.ts",
      "!src/modules/pki/ca.service.ts",
      "!src/modules/pki/cert.service.ts",
      "!src/modules/pki/crl.service.ts",
      "!src/modules/pki/ocsp.service.ts",
      "!src/modules/pki/templates.service.ts",
      "!src/modules/audit/alert.service.ts",
      "!src/modules/audit/audit.service.ts",
      "!src/modules/auth/auth.service.ts",
      "!src/modules/tokens/tokens.service.ts",
      "!src/services/cache.service.ts"
    ]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noAssignInExpressions": "off",
        "noExplicitAny": "off"
      },
      "complexity": {
        "noForEach": "off"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "warn"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useNodejsImportProtocol": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "formatWithErrors": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "semicolons": "always"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
