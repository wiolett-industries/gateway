{
  "name": "frontend",
  "root": "packages/frontend",
  "sourceRoot": "packages/frontend/src",
  "targets": {
    "build": {
      "command": "pnpm --filter frontend build",
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/vite.config.*",
        "{projectRoot}/index.html",
        "{projectRoot}/package.json"
      ],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "dev": {
      "command": "pnpm --filter frontend dev",
      "cache": false
    },
    "lint": {
      "command": "pnpm --filter frontend lint",
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/tests/**/*",
        "{projectRoot}/biome.json",
        "{projectRoot}/package.json",
        "{projectRoot}/vite.config.*",
        "{projectRoot}/vitest.config.*"
      ],
      "cache": true
    },
    "test": {
      "command": "pnpm --filter frontend test",
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/vitest.config.*",
        "{projectRoot}/package.json"
      ],
      "cache": true
    },
    "preview": {
      "command": "pnpm --filter frontend preview",
      "cache": false
    }
  }
}
